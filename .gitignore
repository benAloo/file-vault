# ==========================================
# 1. OS & System Files
# ==========================================
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
*.log
*.tmp
*.bak

# ==========================================
# 2. IDEs & Code Editors
# ==========================================
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
.recommenders/

# ==========================================
# 3. Node.js & Frontend (React/Vite)
# ==========================================
# Ignore node_modules globally across all workspace projects
node_modules/

# Production build outputs
dist/
dist-ssr/
out/
build/

# Vite & ESLint cache
.vite/
.eslintcache
.pnpm-debug.log*
pnpm-debug.log*

# Test coverage reports
coverage/
htmlcov/

# ==========================================
# 4. Rust Backend (Cargo Workspace)
# ==========================================
# Cargo compiles everything to a single shared target folder at the workspace root
/target/

# Backup files generated by cargo formatting/refactoring tools
**/*.rs.bk
cargo-check-history

# ==========================================
# 5. Supabase (Local Development Engine)
# ==========================================
# Local development state cache and link configurations (highly machine-specific)
supabase/.temp/

# Backup/Trash folders for migrations
supabase/migrations/.trash/

# ==========================================
# 6. Security & Secrets (CRITICAL)
# ==========================================
# Never commit environment config files containing access tokens, DB keys, or passwords
.env
.env.local
.env.development
.env.production
.env.test
.env.*.local

# We explicitly DO NOT ignore the template example file so team members can copy it
!.env.example